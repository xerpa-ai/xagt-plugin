{
  "name": "@xagt/agent-plugin",
  "version": "0.1.5",
  "description": "XAgent Skill Agent Plugin installer for Claude Code, OpenClaw-style agents, Cursor, and generic skill runtimes.",
  "type": "module",
  "bin": {
    "xagent-plugin": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    ".cursor-plugin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "xagent",
    "agent",
    "skills",
    "plugin"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
